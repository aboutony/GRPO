# ═══════════════════════════════════════════════════════════════════════
# GRPO Module — Environment Configuration Template
#
# Copy this file to .env and fill in your SAP Business One details.
# ═══════════════════════════════════════════════════════════════════════

# ── SAP Business One Connection ─────────────────────────────────────
SAP_SERVER=sap-b1.your-domain.local
SAP_COMPANY_DB=YOUR_COMPANY_DB
SAP_DB_TYPE=dst_HANADB
SAP_USER=GRPO_SERVICE
SAP_PASSWORD=change-me-to-your-password
SAP_LICENSE_SERVER=sap-lic.your-domain.local:40000

# ── Service Layer ───────────────────────────────────────────────────
SERVICE_LAYER_URL=https://sap-b1.your-domain.local:50000/b1s/v1

# ── GRPO Service ────────────────────────────────────────────────────
GRPO_PORT=8443
GRPO_HOST=0.0.0.0
SYNC_INTERVAL_MS=3000
MAX_BATCH_SIZE=50
OFFLINE_QUEUE_LIMIT=500
DI_POOL_SIZE=5

# ── SABER (Saudi Conformity) ───────────────────────────────────────
SABER_API_URL=https://api.saber.sa/v1
SABER_API_KEY=your-saber-api-key
SABER_MODE=warn

# ── SFDA Export ─────────────────────────────────────────────────────
SFDA_EXPORT_CRON=0 2 * * *
SFDA_EXPORT_FORMAT=XML
SFDA_EXPORT_PATH=/app/exports/sfda

# ── Security ────────────────────────────────────────────────────────
JWT_SECRET=generate-a-256-bit-secret-here
AUDIT_HASH_ALGORITHM=SHA-256

# ── Timezone ────────────────────────────────────────────────────────
TZ=Asia/Riyadh
